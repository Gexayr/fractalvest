# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=fractionalvest
POSTGRES_USER=fvuser
POSTGRES_PASSWORD=change-this-password

# ── API ─────────────────────────────────────────────────────────────────────
# JWT signing secret — must be long and random in production
SESSION_SECRET=change-this-secret-min-32-chars

# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ── Ports ────────────────────────────────────────────────────────────────────
# Host port the web frontend is exposed on (default: 80)
APP_PORT=80
# Internal port the API server listens on (default: 8080)
API_PORT=8080
# Host port PostgreSQL is exposed on (default: 54321)
DB_PORT=54321
