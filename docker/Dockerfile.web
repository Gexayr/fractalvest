# ---- Builder ----
FROM node:24-slim AS builder
RUN corepack enable
WORKDIR /app

COPY . .
RUN pnpm install

# PORT satisfies the vite.config.ts startup check (not used in build output)
ENV PORT=8081
ENV BASE_PATH=/
RUN pnpm --filter @workspace/invest-platform run build

# ---- Runtime ----
FROM nginx:alpine AS runtime
COPY --from=builder /app/artifacts/invest-platform/dist/public /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
